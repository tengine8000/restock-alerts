// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Subscriber {
  id           String    @id @default(cuid())
  shop         String
  productId    String
  variantId    String
  productTitle String?
  variantTitle String?
  email        String
  status       String    @default("PENDING")
  subscribedAt DateTime  @default(now())
  notifiedAt   DateTime?

  @@unique([shop, variantId, email])
  @@index([shop])
  @@index([shop, variantId, status])
}

model NotificationLog {
  id           String   @id @default(cuid())
  subscriberId String
  shop         String
  sentAt       DateTime @default(now())
  status       String
  errorMessage String?
  providerName String?

  @@index([shop])
  @@index([shop, sentAt])
}


model ShopSettings {
  shop                  String    @id
  autoSendEnabled        Boolean   @default(true)
  plan                   String    @default("FREE")
  emailFromName          String    @default("Your Store")
  emailSubject           String    @default("Good news — your item is back in stock!")
  emailBodyHtml          String    @default("")
  onboardingCompletedAt    DateTime?
  reviewPromptDismissedAt  DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}
